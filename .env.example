# 必須 — ヒアリングで決定。フォルダ名・バックアップ名・Compose プロジェクト名に使用
SERVER_NAME=survival-2024

# MOTD — SERVER_NAME から自動生成（1行・シンプル）
MOTD=§6survival-2024§r

# Docker Compose プロジェクト名（通常 SERVER_NAME と同値）
COMPOSE_PROJECT_NAME=survival-2024

# Minecraft サーバー設定
EULA=TRUE
TYPE=PAPER
VERSION=LATEST
MEMORY=4G
MAX_PLAYERS=10
USE_AIKAR_FLAGS=TRUE
OVERRIDE_SERVER_PROPERTIES=TRUE

# ポート
MC_PORT=25565
RCON_PORT=25575

# RCON（推奨: openssl rand -hex 16 で生成）
ENABLE_RCON=TRUE
RCON_PASSWORD=

# Linux / WSL — ホストユーザーと一致させる（id -u / id -g）
UID=1000
GID=1000

# ゲーム設定
ONLINE_MODE=TRUE
DIFFICULTY=normal
WHITE_LIST=FALSE
VIEW_DISTANCE=10
SPAWN_PROTECTION=16

# モッドパック（CurseForge 利用時）
# CF_API_KEY=
# CF_PAGE_URL=
# CF_PARALLEL_DOWNLOADS=8

# モッドパック（Modrinth 利用時）
# MODRINTH_MODPACK=https://modrinth.com/modpack/...
